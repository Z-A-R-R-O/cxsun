# Redis connection values for the separate Redis container.
# Copy or source this file before running setup scripts when custom Redis values are needed.
#
# Example:
#   set -a
#   . .container/database/redis.external.env.sample
#   set +a
#   bash .container/setup-cloud.sh

REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
