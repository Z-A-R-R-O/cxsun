# ─── Server ──────────────────────────────────────────
PORT=6005

# ─── Frontend ─────────────────────────────────────────
VITE_PORT=6010
VITE_API_BASE_URL=http://localhost:6005
VITE_STORAGE_BASE_URL=http://localhost:6005
VITE_MEDIA_MANAGER_URL=http://localhost:6050
DEVELOPER_MODE=false
FRONTEND_URL=http://localhost:6010
CORS_ORIGINS=http://localhost:6010,https://localhost:6010

# Media container
CXMEDIA_PORT=6050
CXMEDIA_ADMIN_PASSWORD=Sundarcomputers@123
CXMEDIA_STORAGE_VOLUME=cxmedia-storage
CXMEDIA_DB_VOLUME=cxmedia-db

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cxsun_master
DB_USER=root
DB_PASSWORD=Computer.1

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ─── Queue / Workers ────────────────────────────────
QUEUE_ENABLED=true
DATABASE_BACKUP_INTERVAL_HOURS=6
INSTALL_RUN_TESTS=false
SKIP_MARIADB_WAIT=true
HEALTH_WAIT_SECONDS=900

# Default/fallback mail settings. Tenants can override these from Mail Settings.
MAIL_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=
MAIL_REPLY_TO=
MAIL_SMTP_HOST=smtp.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true
MAIL_IMAP_HOST=imap.hostinger.com
MAIL_IMAP_PORT=993
MAIL_POP3_HOST=pop.hostinger.com
MAIL_POP3_PORT=995

# ─── JWT / Auth ──────────────────────────────────────
JWT_SECRET=                              # REQUIRED — no fallback

# Optional first platform users. Leave blank on live and create users manually
# unless this deployment intentionally needs a seeded owner account.
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SOFTWARE_ADMIN_NAME=
SOFTWARE_ADMIN_EMAIL=
SOFTWARE_ADMIN_PASSWORD=

# Optional tenant setup helper account. Leave blank on live unless you
# intentionally want every newly setup tenant to receive this admin user.
TENANT_ADMIN_NAME=
TENANT_ADMIN_EMAIL=
TENANT_ADMIN_PASSWORD=

# WhiteBooks GST / e-Invoice / e-Way GSP
# Credentials are managed in the app:
# - super-admin GST API stores base URL, registered email, client ID/secret, and IP.
# - tenant GST API stores username, password, and GSTIN per company/environment.
GSP_ENVIRONMENT=sandbox
GSP_SANDBOX_BASE_URL=https://apisandbox.whitebooks.in
GSP_BASE_URL=https://api.whitebooks.in
