{
  "name": "@cxsun/server",
  "private": true,
  "version": "1.0.86",
  "type": "module",
  "scripts": {
    "dev": "node ../../apps/cli/preflight.mjs server",
    "build": "tsc",
    "start": "node ../../build/server/main.js",
    "db": "tsx src/core/migration-manager/cli.ts",
    "db:refresh": "tsx src/core/migration-manager/cli.ts fresh --tenant=aaran",
    "db:fresh": "tsx src/core/migration-manager/cli.ts fresh",
    "db:migrate": "tsx src/core/migration-manager/cli.ts migrate",
    "db:seed": "tsx src/core/migration-manager/cli.ts seed",
    "db:setup": "tsx src/core/migration-manager/cli.ts setup",
    "lint": "eslint .",
    "test:master-data": "tsx src/modules/foundation/master-data/tests/master-data-contract.test.ts",
    "test:tenant-static": "tsx src/modules/site/tests/tenant-static-content.test.ts",
    "test:tenant-isolation": "tsx src/modules/site/tests/tenant-isolation-contract.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cxsun/shared": "*",
    "@fastify/cors": "^11.2.0",
    "@types/nodemailer": "^8.0.0",
    "bullmq": "^5.77.3",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "kysely": "^0.29.0",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.10",
    "playwright": "^1.60.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  }
}
