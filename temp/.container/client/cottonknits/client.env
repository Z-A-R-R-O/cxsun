CLIENT_ENV_FILE=./cottonknits/client.env

# Application
APP_NAME=cottonknits

# Core host identity, listening endpoints, TLS, and filesystem roots.
APP_ENV=production
APP_TYPE=100
APP_CLIENT=100
APP_HOST=0.0.0.0
APP_DOMAIN=cotton.codexsun.com
APP_HTTP_PORT=4000

# Frontend
FRONTEND_HTTP_PORT=3000
NEXT_PUBLIC_SETUP_LOOKUP_ENABLED=false
FRONTEND_URL=https://cotton.codexsun.com
BACKEND_URL=https://cotton.codexsun.com
BACKEND_HEALTH_URL=https://cotton.codexsun.com/health
NEXT_PUBLIC_API_URL=https://cotton.codexsun.com/api/v1
CORS_ORIGINS=https://cotton.codexsun.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3006,http://127.0.0.1:3006

# Backend
DESKTOP_READY_TIMEOUT_MS=30000
DEV_READY_TIMEOUT_MS=60000

# Deployment
GIT_URL=https://github.com/sundar-aaran/cxnext.git
GIT_BRANCH=main
SYSTEM_UPDATE_ENABLED=true
SYSTEM_UPDATE_AUTO_ENABLED=false
SYSTEM_UPDATE_AUTO_CRON="0 3 * * *"
SMOKE_TEST_ENABLED=false
SMOKE_TEST_TIMEOUT_MS=60000
DEPLOY_DIR=/deploy/cxnext
COMPOSE_PROJECT_NAME=cxnext-cottonknits
COMPOSE_FILE=.container/client/docker-compose.yml
APP_CONTAINER_NAME=cottonknits-app
APP_VERSION=v1
APP_PUBLIC_PORT=4022
FRONTEND_PUBLIC_PORT=3006

# Database
DB_DRIVER=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=cottonknits_db
DB_USER=root
DB_PASSWORD=DbPass1@@
DB_SSL=false

# Security
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN_SECONDS=28800
AUTH_TOKEN_EXPIRES_SECONDS=28800
AUTH_DEFAULT_ADMIN_PASSWORD=Admin@1234
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=30
ADMIN_SESSION_IDLE_MINUTES=30
SECRET_ROTATION_DAYS=90

# Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@example.com
SMTP_PASS=change-me
SMTP_FROM_EMAIL=user@example.com
SMTP_FROM_NAME="CX Next"

# Razorpay
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=change-me
RAZORPAY_KEY_SECRET=change-me
