# Application
APP_NAME=codexsun

# Core host identity, listening endpoints, TLS, and filesystem roots.
APP_ENV=development
APP_TYPE=200
APP_CLIENT=100
APP_HOST=0.0.0.0
APP_DOMAIN=api.codexsun.local
APP_HTTP_PORT=4000
APP_HTTPS_PORT=4003
CLOUDFLARE_ENABLED=false
TLS_ENABLED=false

# Frontend
FRONTEND_DOMAIN=app.cxnext.local
FRONTEND_HTTP_PORT=3000
FRONTEND_HTTPS_PORT=3001
NEXT_PUBLIC_SETUP_LOOKUP_ENABLED=false

# Backend
DESKTOP_READY_TIMEOUT_MS=30000
DESKTOP_START_SERVICES=true
DESKTOP_PREPARE_DB=true
DESKTOP_CLIENT=codexsun
DB_ENV_FILE=.env.desktop.local
DEV_READY_TIMEOUT_MS=60000

# Deployment
GIT_URL=https://github.com/sundar-aaran/cxnext.git
GIT_BRANCH=main
SYSTEM_UPDATE_ENABLED=true
SMOKE_TEST_ENABLED=false
SMOKE_TEST_TIMEOUT_MS=60000
SYSTEM_UPDATE_AUTO_ENABLED=false
SYSTEM_UPDATE_AUTO_CRON="0 3 * * *"
DEPLOY_DIR=/deploy/cxnext
COMPOSE_PROJECT_NAME=cxnext
COMPOSE_FILE=.container/docker-compose.yml
APP_CONTAINER_NAME=cxnext-app
APP_VERSION=local
APP_PUBLIC_PORT=4000
FRONTEND_PUBLIC_PORT=3000

# Database
DB_DRIVER=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=cxnext_db
DB_USER=root
DB_PASSWORD=DbPass1@@
DB_SSL=false

# Security
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN_SECONDS=28800
AUTH_TOKEN_EXPIRES_SECONDS=28800
AUTH_DEFAULT_ADMIN_PASSWORD=Admin@1234
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=30
ADMIN_SESSION_IDLE_MINUTES=30
SECRET_ROTATION_DAYS=90

# Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@example.com
SMTP_PASS=change-me
SMTP_FROM_EMAIL=user@example.com
SMTP_FROM_NAME="CX Next"

# Razorpay
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=change-me
RAZORPAY_KEY_SECRET=change-me
