# CX Next desktop sidecar env
#
# Copy this file beside the built Electron app as one of:
# - .env.desktop.local
# - .env.desktop
# - .env
# - desktop.env
#
# Or point to a custom file with:
# - CXNEXT_ENV_FILE=C:\path\to\desktop.env
#
# Values here stay outside the bundled Electron build, so you can change
# credentials and endpoints without rebuilding the app.

APP_HOST=127.0.0.1
APP_HTTP_PORT=4000
FRONTEND_HTTP_PORT=3000
FRONTEND_URL=http://127.0.0.1:3000
BACKEND_URL=http://127.0.0.1:4000
BACKEND_HEALTH_URL=http://127.0.0.1:4000/health
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api/v1

DESKTOP_START_SERVICES=false
DESKTOP_PREPARE_DB=false
DESKTOP_READY_TIMEOUT_MS=90000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cxnext_db
DB_USER=root
DB_PASSWORD=change-me
