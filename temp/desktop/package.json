{
  "name": "@cxnext/desktop",
  "version": "1.0.93",
  "private": true,
  "description": "CX Next desktop application",
  "author": "Codexsun",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.json\" \"wait-on dist/main.js && electron dist/main.js\"",
    "build": "tsc -p tsconfig.json",
    "build:installer": "electron-builder --win --publish never",
    "build:dir": "electron-builder --dir --publish never",
    "start": "electron dist/main.js",
    "lint": "eslint . --config ../../eslint.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.cxnext.desktop",
    "productName": "CX Next",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "env.desktop.sample",
        "to": "env.desktop.sample"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "concurrently": "^9.2.1",
    "electron": "42.0.1",
    "electron-builder": "25.1.8",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.6"
  }
}
