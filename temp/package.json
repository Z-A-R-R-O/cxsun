{
  "name": "codexsun",
  "private": true,
  "version": "1.0.284",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm:server:dev\" \"vite\"",
    "server:dev": "tsx watch apps/cxapp/src/server/index.ts",
    "cxmedia:dev": "tsx watch cxmedia/src/server.ts",
    "cxmedia:dev:web": "vite -c cxmedia/vite.config.ts",
    "cxmedia:dev:full": "concurrently -k -n cxmedia,web \"npm:cxmedia:dev\" \"npm:cxmedia:dev:web\"",
    "mobile:dev": "npm --prefix apps/mobile run start",
    "mobile:dev:go": "npm --prefix apps/mobile run go",
    "mobile:dev:go:tunnel": "npm --prefix apps/mobile run go:tunnel",
    "mobile:dev:full": "concurrently -k -n server,mobile \"npm:server:dev\" \"npm:mobile:dev:go\"",
    "mobile:dev:full:tunnel": "concurrently -k -n server,mobile \"npm:server:dev\" \"npm:mobile:dev:go:tunnel\"",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:web": "npm --prefix apps/mobile run web",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "start": "node build/app/cxapp/server/apps/cxapp/src/server/index.js",
    "version:sync": "tsx apps/cli/src/version-helper.ts",
    "github": "tsx apps/cli/src/github-helper.ts",
    "github:now": "tsx apps/cli/src/github-helper.ts --yes",
    "github:server": "npm run server:build && node build/app/cxapp/server/apps/cli/src/github-helper.js",
    "github:server:now": "npm run server:build && node build/app/cxapp/server/apps/cli/src/github-helper.js --yes",
    "db:prepare": "tsx apps/cli/src/database-helper.ts prepare",
    "db:fresh": "tsx apps/cli/src/database-helper.ts fresh --yes",
    "db:migrate": "tsx apps/cli/src/database-helper.ts migrate",
    "db:seed": "tsx apps/cli/src/database-helper.ts seed",
    "db:status": "tsx apps/cli/src/database-helper.ts status",
    "hosted:status": "tsx apps/cli/src/hosted-app-helper.ts status",
    "hosted:update-clean": "tsx apps/cli/src/hosted-app-helper.ts update-clean",
    "remote:status": "tsx apps/cli/src/remote-server-control-helper.ts status",
    "remote:update": "tsx apps/cli/src/remote-server-control-helper.ts git-update",
    "build": "npm run typecheck && vite build && npm run server:build",
    "server:build": "tsc -p tsconfig.server.json",
    "cxmedia:build": "tsc -p cxmedia/tsconfig.json && vite build -c cxmedia/vite.config.ts",
    "cxmedia:docker:up": "tsx cxmedia/deploy/docker-stack.ts up",
    "cxmedia:docker:down": "tsx cxmedia/deploy/docker-stack.ts down",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "cxmedia:typecheck": "tsc -p cxmedia/tsconfig.json --noEmit && tsc -p cxmedia/tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "tsx --test tests/**/*.test.ts cxmedia/tests/**/*.test.ts",
    "cxmedia:test": "tsx --test cxmedia/tests/**/*.test.ts",
    "cxmedia:test:thumbor": "tsx --test cxmedia/tests/thumbor-container.test.ts",
    "cxmedia:test:e2e": "tsx cxmedia/deploy/run-e2e.ts",
    "test:e2e": "playwright test",
    "test:e2e:storefront-smoke": "playwright test tests/e2e/storefront-order-flow.spec.ts tests/e2e/storefront-checkout.spec.ts tests/e2e/storefront-accessibility.spec.ts tests/e2e/storefront-mobile-matrix.spec.ts",
    "test:e2e:ecommerce-admin-ops": "playwright test tests/e2e/ecommerce-admin-operations.spec.ts",
    "test:release:security-ops": "tsx --test tests/api/internal/routes.test.ts --test-name-pattern \"authenticated framework alerts dashboard route returns monitoring summaries|authenticated framework backup and security review routes return operational data\" && playwright test tests/e2e/framework-operations.spec.ts",
    "test:release:env": "tsx apps/cli/src/release-env-check.ts",
    "test:e2e:performance": "playwright test -c playwright.performance.config.ts",
    "cxmedia:start": "node build/cxmedia/server.js",
    "zetro:dev": "tsx watch apps/zetro/src/server.ts",
    "zetro:start": "tsx apps/zetro/src/server.ts",
    "zetro:test": "tsx --test apps/zetro/tests/**/*.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/react": "^0.3.2",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electric-sql/pglite": "^0.4.5",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "kysely": "^0.28.14",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "mysql2": "^3.20.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "p-queue": "^9.2.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.8.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "ws": "^8.13.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.0",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "monaco-editor": "^0.55.1",
    "playwright": "^1.59.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "typescript-language-server": "^5.1.3",
    "vite": "^8.0.1"
  }
}
