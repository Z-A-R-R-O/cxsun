{
  "name": "cxnext",
  "version": "1.0.93",
  "private": true,
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "dev:all": "node scripts/dev-start.mjs --desktop",
    "dev:turbo": "turbo dev",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:restart": "node scripts/dev-start.mjs",
    "start": "node scripts/start.mjs",
    "start:all": "node scripts/start.mjs --desktop",
    "start:frontend": "corepack pnpm --filter @cxnext/frontend start",
    "start:server": "corepack pnpm --filter @cxnext/server start",
    "start:desktop": "corepack pnpm --filter @cxnext/desktop start",
    "desktop:offline": "node scripts/desktop-offline.mjs",
    "stop": "node scripts/dev-stop.mjs",
    "start:stop": "node scripts/dev-stop.mjs",
    "build": "corepack pnpm -r --no-bail build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:electron:dir": "node scripts/build-electron.mjs --dir",
    "build:electron:only": "node scripts/build-electron.mjs --package-only",
    "db:migrate": "corepack pnpm --filter @cxnext/db db:migrate",
    "db:prepare": "corepack pnpm --filter @cxnext/db db:prepare",
    "db:fresh": "corepack pnpm --filter @cxnext/db db:fresh",
    "db:refresh": "corepack pnpm --filter @cxnext/db db:refresh",
    "db:seed": "corepack pnpm --filter @cxnext/db db:seed",
    "db:status": "corepack pnpm --filter @cxnext/db db:status",
    "deploy:build": "docker compose -f .container/docker-compose.yml build app",
    "deploy:restart": "docker compose -f .container/docker-compose.yml up -d app",
    "deploy:status": "node scripts/system-update.mjs status",
    "deploy:update": "node scripts/system-update.mjs deploy",
    "system:update": "node scripts/system-update.mjs deploy",
    "system:update:preflight": "node scripts/system-update.mjs preflight",
    "system:update:sync": "node scripts/system-update.mjs sync",
    "smoke:test": "node scripts/smoke-test.mjs",
    "test:api:e2e": "node tests/e2e/versioned-api-smoke.mjs",
    "setup:status": "node scripts/setup.mjs status",
    "setup:configure": "node scripts/setup.mjs configure",
    "setup:deploy": "node scripts/setup.mjs deploy",
    "lint": "corepack pnpm -r --no-bail lint",
    "typecheck": "corepack pnpm -r --no-bail typecheck",
    "test": "vitest run",
    "github": "node apps/cli/src/github-helper.mjs",
    "github:now": "node apps/cli/src/github-now.mjs",
    "version:sync": "node scripts/version-sync.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "@cxnext/config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
