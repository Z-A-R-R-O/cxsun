{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/ui/src/*"],
      "@ui/*": ["./apps/ui/src/*"],
      "@framework/*": ["./apps/framework/src/*"],
      "@cxapp/*": ["./apps/cxapp/*"],
      "@cxsun/*": ["./apps/cxsun/*"],
      "@site/*": ["./apps/site/*"],
      "@core/*": ["./apps/core/*"],
      "@api/*": ["./apps/api/*"],
      "@billing/*": ["./apps/billing/*"],
      "@demo/*": ["./apps/demo/*"],
      "@ecommerce/*": ["./apps/ecommerce/*"],
      "@task/*": ["./apps/task/*"],
      "@crm/*": ["./apps/crm/*"],
      "@zetro/*": ["./apps/zetro/*"],
      "@frappe/*": ["./apps/frappe/*"],
      "@tally/*": ["./apps/tally/*"],
      "@cli/*": ["./apps/cli/*"],
      "next/image": ["./apps/ui/src/compat/next-image.tsx"],
      "next/link": ["./apps/ui/src/compat/next-link.tsx"]
    }
  },
  "include": [
    "apps/framework/src/application/**/*.ts",
    "apps/framework/src/di/browser-container.ts",
    "apps/framework/src/di/service-container.ts",
    "apps/framework/src/di/tokens.ts",
    "apps/framework/engines/**/*.ts",
    "apps/framework/lib/**/*.ts",
    "apps/framework/manifests/**/*.ts",
    "apps/framework/runtime/**/*.ts",
    "apps/framework/testing/**/*.ts",
    "apps/*/web/**/*.ts",
    "apps/*/web/**/*.tsx",
    "apps/*/src/app-manifest.ts",
    "apps/cxsun/src/**/*.ts",
    "apps/*/helper/**/*.ts",
    "apps/*/shared/**/*.ts",
    "apps/ui/src/app-manifest.ts",
    "apps/ui/src/assets/**/*",
    "apps/ui/src/components/**/*",
    "apps/ui/src/lib/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "apps/ui/src/registry/**/*"
  ]
}
